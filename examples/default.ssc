// SoundScript default timbre stylesheet (V4.1)
p {
    burst: 12ms;
    noise-plosive: 0.4;
    harmonic1: 0.2;
    harmonic2: 0.1;
}

aa {
    formant1: 700Hz;
    formant2: 1100Hz;
    smoothness: 0.9;
    harmonic1: 0.9;
    harmonic2: 0.6;
    harmonic3: 0.3;
    noise-fricative: 0.2;
    transient: 8ms;
}
