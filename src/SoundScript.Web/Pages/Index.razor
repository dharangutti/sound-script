<div class="demo-page">
    <header class="demo-header">
        <a class="demo-brand" href="/" aria-label="SoundScript home">
            <img src="assets/soundscript-logo.png" alt="SoundScript" />
        </a>
        <div class="demo-badge">SoundScript Web Demo · @VersionInfo.Label</div>
        <h1>Text → MIDI</h1>
        <p class="demo-lead">Write a melody in the box below, generate MIDI, and download — all in your browser.</p>
        <p class="demo-lead">Prefer starting from text? The <a href="/playground">Playground</a> composes plain English into a melody and can export it as editable <code>.ss</code> source you can hand-tweak and re-run.</p>
    </header>

    <div class="demo-presets">
        <span class="preset-label">Examples:</span>
        <button class="btn btn-sm btn-outline-secondary" @onclick="LoadMelodyExample">Melody</button>
        <button class="btn btn-sm btn-outline-secondary" @onclick="LoadDurationsExample">Durations</button>
    </div>

    <div class="demo-editor">
        <label for="script-input" class="demo-label">SoundScript</label>
        <textarea id="script-input"
                  class="demo-textarea"
                  @bind="ScriptText"
                  rows="14"
                  spellcheck="false"
                  placeholder="melody { ... }"></textarea>
    </div>

    <div class="demo-actions">
        <button class="btn btn-primary btn-lg" @onclick="Generate">Generate MIDI</button>
    </div>

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="demo-error" role="alert">@ErrorMessage</div>
    }

    @if (MidiBytes != null)
    {
        <div class="demo-success">
            <span>MIDI ready — @MidiBytes.Length bytes</span>
            <a class="btn btn-success"
               href="data:audio/midi;base64,@Convert.ToBase64String(MidiBytes)"
               download="soundscript.mid">
                Download MIDI
            </a>
        </div>
    }
</div>
