<div class="playground">
    <header class="playground-header">
        <div class="header-top">
            <a class="home-link" href="/">← SoundScript</a>
            <span class="badge">Playground · V2</span>
        </div>
        <h1>SoundScript Playground</h1>
        <p class="lead">Type SoundScript V2, compile to MIDI, and hear it in your browser — fully client-side.</p>
    </header>

    <div class="presets">
        <span class="preset-label">V2:</span>
        <button type="button" class="btn btn-secondary" @onclick="LoadV2ShowcaseExample">Showcase</button>
        <button type="button" class="btn btn-secondary" @onclick="LoadBlocksExample">Blocks</button>
        <button type="button" class="btn btn-secondary" @onclick="LoadMetadataExample">Metadata</button>
        <button type="button" class="btn btn-secondary" @onclick="LoadTempoExample">Tempo</button>
        <button type="button" class="btn btn-secondary" @onclick="LoadLayersExample">Layers</button>
        <button type="button" class="btn btn-secondary" @onclick="LoadHumanizeExample">Humanize</button>
        <button type="button" class="btn btn-secondary" @onclick="LoadAdvancedChordsExample">Chords+</button>
        <button type="button" class="btn btn-secondary" @onclick="LoadPhrasesExample">Phrases</button>
        <button type="button" class="btn btn-secondary" @onclick="LoadV3PhrasesExample">Phrases V3</button>
        <button type="button" class="btn btn-secondary" @onclick="LoadPatternsExample">Patterns</button>
        <button type="button" class="btn btn-secondary" @onclick="LoadOrchestrationExample">Orchestration</button>
        <button type="button" class="btn btn-secondary" @onclick="LoadVoiceExample">Voice</button>
    </div>

    <div class="presets">
        <span class="preset-label">Text-to-Melody:</span>
        <input class="compose-input"
               @bind="ComposeText"
               spellcheck="false"
               placeholder="Type plain text to compose from" />
        <button type="button" class="btn btn-secondary" disabled="@IsRunning" @onclick="ComposeFromTextAsync">Compose from text</button>
        <button type="button" class="btn btn-secondary" disabled="@IsRunning" @onclick="RenderAudioAsync">Render Audio</button>
    </div>

    <div class="presets">
        <span class="preset-label">Core:</span>
        <button type="button" class="btn btn-secondary" @onclick="LoadMelodyExample">Melody</button>
        <button type="button" class="btn btn-secondary" @onclick="LoadArticulationsExample">Articulations</button>
        <button type="button" class="btn btn-secondary" @onclick="LoadDynamicsExample">Dynamics</button>
        <button type="button" class="btn btn-secondary" @onclick="LoadChordsExample">Chords</button>
        <button type="button" class="btn btn-secondary" @onclick="LoadIntelligenceExample">Intelligence</button>
        <button type="button" class="btn btn-secondary" @onclick="LoadMultitrackExample">Multi-track</button>
        <button type="button" class="btn btn-secondary" @onclick="LoadPlaybackExample">Playback</button>
    </div>

    <div class="panes">
        <section class="pane pane-editor">
            <label class="pane-label" for="script-input">SoundScript</label>
            <textarea id="script-input"
                      class="script-input"
                      @bind="ScriptText"
                      spellcheck="false"
                      placeholder="track melody { ... }"></textarea>
        </section>

        <section class="pane pane-output">
            <label class="pane-label">Output</label>

            <div class="actions">
                <button type="button" class="btn btn-primary" disabled="@IsRunning" @onclick="RunAsync">
                    @(IsRunning ? "Running…" : "Run")
                </button>
                <button type="button" class="btn btn-secondary" @onclick="StopAsync">Stop</button>
                @if (MidiBytes is not null)
                {
                    <button type="button" class="btn btn-secondary" @onclick="DownloadAsync">Download MIDI</button>
                }
                @if (WavBytes is not null)
                {
                    <button type="button" class="btn btn-secondary" @onclick="DownloadWavAsync">Download WAV</button>
                }
            </div>

            @if (!string.IsNullOrEmpty(StatusMessage))
            {
                <div class="status" role="status">@StatusMessage</div>
            }

            @if (WarningMessages.Count > 0)
            {
                <div class="warning" role="status">
                    <strong>Warnings</strong>
                    <ul>
                        @foreach (var warning in WarningMessages)
                        {
                            <li>@warning</li>
                        }
                    </ul>
                </div>
            }

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="error" role="alert">
                    <strong>Error</strong>
                    <pre>@ErrorMessage</pre>
                </div>
            }

            <div class="pipeline">
                <span>Tokenizer</span>
                <span class="arrow">→</span>
                <span>Parser</span>
                <span class="arrow">→</span>
                <span>Interpreter</span>
                <span class="arrow">→</span>
                <span>PhraseTimingShaper</span>
                <span class="arrow">→</span>
                <span>PhraseShaper</span>
                <span class="arrow">→</span>
                <span>PatternExpander</span>
                <span class="arrow">→</span>
                <span>Orchestration</span>
                <span class="arrow">→</span>
                <span>Layers</span>
                <span class="arrow">→</span>
                <span>Humanize</span>
                <span class="arrow">→</span>
                <span>MIDI</span>
                <span class="arrow">+</span>
                <span>Voice</span>
                <span class="arrow">+</span>
                <span>PhonemeComposer</span>
                <span class="arrow">→</span>
                <span>SoundCSS</span>
                <span class="arrow">→</span>
                <span>Timbre</span>
            </div>

            <p class="hint">
                No server, no API calls. Imports use the CLI (<code>ProgramLoader</code>); all other V2 features run here.
                <code>voice</code> blocks speak their lyrics through your browser's speech synthesis while the melody plays —
                the downloaded MIDI carries the lyrics as standard karaoke events.
                <strong>Compose from text</strong> runs the deterministic <code>PhonemeComposer</code>
                (text → syllables → phonemes → gestures → MIDI): the same text always produces the same MIDI bytes.
                <strong>Render Audio</strong> adds the V4 offline timbre pass (MIDI → SoundCSS → WAV) — slow-motion synthesis, not real-time playback.
            </p>
        </section>
    </div>
</div>
