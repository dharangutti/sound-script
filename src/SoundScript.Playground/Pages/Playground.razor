<div class="playground">
    <header class="playground-header">
        <div class="header-top">
            <a class="brand-link" href="/" aria-label="SoundScript home">
                <img class="brand-logo" src="assets/soundscript-logo.png" alt="SoundScript" />
            </a>
            <span class="badge">Playground · @VersionInfo.Label</span>
        </div>
        <h1>SoundScript Playground</h1>
        <p class="lead">Type SoundScript V2, compile to MIDI, and hear it in your browser — fully client-side.</p>
    </header>

    <div class="presets">
        <span class="preset-label">Example:</span>
        <select class="example-select" @bind="SelectedExampleKey" @bind:after="LoadSelectedExampleAsync">
            <optgroup label="V2">
                <option value="v2-showcase">Showcase</option>
                <option value="v2-blocks">Blocks</option>
                <option value="v2-metadata">Metadata</option>
                <option value="v2-tempo">Tempo</option>
                <option value="v2-layers">Layers</option>
                <option value="v2-humanize">Humanize</option>
                <option value="v2-chords">Chords+</option>
                <option value="v2-phrases">Phrases</option>
                <option value="v2-phrases-v3">Phrases V3</option>
                <option value="v2-patterns">Patterns</option>
                <option value="v2-orchestration">Orchestration</option>
                <option value="v2-voice">Voice</option>
            </optgroup>
            <optgroup label="Core">
                <option value="core-melody">Melody</option>
                <option value="core-articulations">Articulations</option>
                <option value="core-dynamics">Dynamics</option>
                <option value="core-chords">Chords</option>
                <option value="core-intelligence">Intelligence</option>
                <option value="core-multitrack">Multi-track</option>
                <option value="core-playback">Playback</option>
            </optgroup>
            <optgroup label="Showcase">
                <option value="showcase-jingle-bells">Jingle Bells (full showcase)</option>
                <option value="showcase-jingle-bells-wave">Jingle Bells (Wave / speak overlay)</option>
            </optgroup>
            <!-- UNDER DEVELOPMENT — v3: these examples use wave-only grammar
                 (effect/speak, humanize's named form); Run detects it in the
                 AST and renders via SoundScript.Wave instead of MIDI. -->
            <optgroup label="Wave (.ssw)">
                <option value="wave-effects">Effects (delay + filter)</option>
                <option value="wave-speak">Speak (prosody tone)</option>
                <option value="wave-humanize">Seeded humanize + speak</option>
                <option value="wave-effects-combined">Combined (wave-effects.ssw)</option>
                <option value="wave-full-song">Full song (full-song-wave.ss)</option>
                <option value="speech-only-wave">Speech-only (speech-only-wave.ss)</option>
                <option value="wave-vocal-stem">Vocal stem (wave-vocal-stem.ssw)</option>
                <option value="jingle-bells-vocal">Jingle Bells + offline vocal</option>
                <option value="jingle-bells-wordbank">Jingle Bells + WordBank vocal (V9)</option>
            </optgroup>
        </select>
        @if (ActiveMainPreset is not null)
        {
            <span class="preset-active-title">@ActiveMainPreset.Title</span>
        }
    </div>

    <div class="playground-playbar" role="toolbar" aria-label="Compile and play">
        <button type="button" class="btn btn-primary" disabled="@IsRunning" @onclick="RunAsync">
            @(IsRunning ? "Running…" : "Run")
        </button>
        <button type="button" class="btn btn-secondary" @onclick="StopAsync">Stop</button>
        @if (MidiBytes is not null)
        {
            <button type="button" class="btn btn-secondary" @onclick="DownloadAsync">Download MIDI</button>
        }
        @if (WavBytes is not null)
        {
            <button type="button" class="btn btn-secondary" @onclick="DownloadWavAsync">Download WAV</button>
        }
        @if (SsText is not null)
        {
            <button type="button" class="btn btn-secondary" @onclick="DownloadSsAsync">Download .ss</button>
        }
        @if (UsedWaveBackend)
        {
            <span class="badge badge-playbar">SoundScript.Wave · no MIDI step</span>
        }
    </div>

    <div class="panes">
        <section class="pane pane-editor">
            <label class="pane-label" for="script-input">SoundScript</label>
            <div class="editor-toolbar">
                <button type="button" class="btn btn-primary btn-toolbar-run" disabled="@IsRunning" @onclick="RunAsync">
                    @(IsRunning ? "Running…" : "Run")
                </button>
                <button type="button" class="btn btn-secondary" @onclick="StopAsync">Stop</button>
                <button type="button" class="btn btn-secondary" @onclick="() => ClearEditorAsync(MidiEditorId)">Clear</button>
                <button type="button" class="btn btn-secondary" @onclick="() => ResetEditorAsync(MidiEditorId)">Reset</button>
                <button type="button" class="btn btn-secondary" @onclick="() => CopyEditorAsync(MidiEditorId)">Copy</button>
                <button type="button" class="btn btn-secondary" @onclick="() => UndoEditorAsync(MidiEditorId)">Undo</button>
                <button type="button" class="btn btn-secondary" @onclick="() => RedoEditorAsync(MidiEditorId)">Redo</button>
                <button type="button" class="btn btn-secondary" @onclick="() => ToggleThemeAsync(MidiEditorId)">Theme</button>
                <button type="button" class="btn btn-secondary" disabled="@IsRunning" @onclick="DownloadCurrentScriptAsync">Download script</button>
                <button type="button" class="btn btn-secondary" title="Load this example into the SoundCSS studio below"
                        @onclick="StyleInStudioAsync">Style in Studio ↓</button>
            </div>
            <div class="editor-mount" id="@MidiEditorId"></div>

            <details class="midi-css-panel">
                <summary>SoundCSS timbre (applied to <strong>Render Audio</strong>) ⓘ</summary>
                <p class="hint">
                    Phoneme-level rules (<code>p</code>, <code>aa</code>, …) shape the offline
                    MIDI → SoundCSS → WAV render below. Leave empty to use the built-in default
                    stylesheet. (Word rules like <code>"hello" { … }</code> apply to the Wave
                    Studio's vocal engine, not the MIDI timbre pass.)
                </p>
                <div class="editor-mount editor-mount-css" id="@MidiCssEditorId"></div>
            </details>
        </section>

        <section class="pane pane-output">
            <label class="pane-label">Output</label>

            @if (!string.IsNullOrEmpty(StatusMessage))
            {
                <div class="status" role="status">@StatusMessage</div>
            }

            @if (WarningMessages.Count > 0)
            {
                <div class="warning" role="status">
                    <strong>Warnings</strong>
                    <ul>
                        @foreach (var warning in WarningMessages)
                        {
                            <li>@warning</li>
                        }
                    </ul>
                </div>
            }

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="error" role="alert">
                    <strong>Error</strong>
                    <pre>@ErrorMessage</pre>
                </div>
            }

            @if (SsText is not null)
            {
                <details class="ss-preview">
                    <summary>View .ss source</summary>
                    <pre>@SsText</pre>
                </details>
            }

            <details class="pipeline-collapse" open>
                <summary>Pipeline</summary>
            <div class="pipeline">
                <span>Tokenizer</span>
                <span class="arrow">→</span>
                <span>Parser</span>
                <span class="arrow">→</span>
                <span>Interpreter</span>
                <span class="arrow">→</span>
                <span>PhraseTimingShaper</span>
                <span class="arrow">→</span>
                <span>PhraseShaper</span>
                <span class="arrow">→</span>
                <span>PatternExpander</span>
                <span class="arrow">→</span>
                <span>Orchestration</span>
                <span class="arrow">→</span>
                <span>Layers</span>
                <span class="arrow">→</span>
                <span>Humanize</span>
                <span class="arrow">→</span>
                <span>MIDI</span>
                <span class="arrow">+</span>
                <span>Voice</span>
                <span class="arrow">+</span>
                <span>PhonemeComposer</span>
                <span class="arrow">+</span>
                <span>ProsodyComposer</span>
                <span class="arrow">→</span>
                <span>SoundCSS</span>
                <span class="arrow">→</span>
                <span>Timbre</span>
            </div>

            @if (UsedWaveBackend)
            {
                <div class="pipeline">
                    <span>Tokenizer</span>
                    <span class="arrow">→</span>
                    <span>Parser</span>
                    <span class="arrow">→</span>
                    <span>SoundScript.Wave</span>
                    <span class="arrow">+</span>
                    <span>MasterEffectChain</span>
                    <span class="arrow">+</span>
                    <span>ProsodyToneGenerator</span>
                    <span class="arrow">→</span>
                    <span>WAV</span>
                </div>
            }
            </details>

            <details class="output-hint">
                <summary>About this playground</summary>
                <p class="hint">
                    No server, no API calls. Imports use the CLI (<code>ProgramLoader</code>); all other V2 features run here.
                    <code>voice</code> blocks speak their lyrics through your browser's speech synthesis while the melody plays —
                    the downloaded MIDI carries the lyrics as standard karaoke events.
                    <strong>Compose from text</strong> runs the deterministic <code>PhonemeComposer</code>
                    (text → syllables → phonemes → gestures → MIDI): the same text always produces the same MIDI bytes.
                    <strong>Compose with Prosody</strong> runs the V5 <code>ProsodyComposer</code> instead — pitch is
                    planned top-down (phrase → word → syllable) so the melody follows spoken stress and sentence
                    contour rather than a fixed pitch per phoneme.
                    <strong>Render Audio</strong> adds the V4 offline timbre pass (MIDI → SoundCSS → WAV) — slow-motion synthesis, not real-time playback.
                    <strong>Render Audio (Prosody)</strong> runs the same offline timbre pass over the <code>ProsodyComposer</code> MIDI instead —
                    same phoneme timbre, word/syllable-shaped pitch.
                    Both compose buttons also produce an editable <strong>.ss</strong> export (V6) — view it inline,
                    download it, hand-tweak a note, and run it through <code>soundscript run</code> to hear exactly your edit.
                    <strong>Run</strong> also understands wave-only grammar (<code>effect delay/filter</code>, <code>speak</code>,
                    and <code>humanize</code>'s named <code>timing=/velocity=/seed=</code> form) — a script using any of it
                    skips MIDI entirely and renders straight to WAV through <strong>SoundScript.Wave</strong>, byte-identical
                    for the same script text every time. Everything else still plays through MIDI, unchanged.
                    → <a href="/doc.html?p=wave-grammar.md" target="_blank" rel="noopener">.ssw grammar reference</a>.
                </p>
            </details>
        </section>
    </div>

    @if (ActiveMainPreset is not null)
    {
        <details class="example-cli-panel">
            <summary>Example CLI — @ActiveMainPreset.Title (@ActiveMainPreset.OutputRailShortLabel)</summary>
            <div class="example-cli-header">
                <span class="badge badge-rail">@ActiveMainPreset.OutputRailLabel</span>
                <span class="example-cli-action">Playground: <strong>@ActiveMainPreset.PlaygroundAction</strong></span>
            </div>
            @if (ActiveMainPreset.ExampleFile is not null)
            {
                <p class="example-cli-file">
                    Example file:
                    <a href="@ActiveMainPreset.ExampleRepoUrl" target="_blank" rel="noopener noreferrer">examples/@ActiveMainPreset.ExampleFile</a>
                    · <a href="@ActiveMainPreset.DocsUrl" target="_blank" rel="noopener noreferrer">docs catalog</a>
                </p>
            }
            else
            {
                <p class="example-cli-file example-cli-muted">No on-disk file — inline Playground preset only.</p>
            }
            @if (!string.IsNullOrWhiteSpace(ActiveMainPreset.Notes))
            {
                <p class="example-cli-notes">@ActiveMainPreset.Notes</p>
            }
            <ol class="cli-steps">
                @for (var i = 0; i < ActiveMainPreset.CliSteps.Count; i++)
                {
                    var line = ActiveMainPreset.CliSteps[i];
                    <li>
                        <code class="cli-line">@line</code>
                        <button type="button" class="btn btn-secondary btn-copy-cli" @onclick="() => CopyCliLineAsync(line)">Copy</button>
                    </li>
                }
            </ol>
        </details>
    }

    <div class="presets presets-text">
        <span class="preset-label">Text-to-Melody:</span>
        <input class="compose-input"
               @bind="ComposeText"
               spellcheck="false"
               placeholder="Type plain text to compose from" />
        <button type="button" class="btn btn-secondary" disabled="@IsRunning" @onclick="ComposeFromTextAsync">Compose from text</button>
        <button type="button" class="btn btn-secondary" disabled="@IsRunning" @onclick="ComposeWithProsodyAsync">Compose with Prosody</button>
        <button type="button" class="btn btn-secondary" disabled="@IsRunning" @onclick="RenderAudioAsync">Render Audio</button>
        <button type="button" class="btn btn-secondary" disabled="@IsRunning" @onclick="RenderAudioWithProsodyAsync">Render Audio (Prosody)</button>
        <button type="button" class="btn btn-secondary" disabled="@IsRunning" @onclick="RenderWaveFromTextAsync">Render Wave</button>
        <button type="button" class="btn btn-secondary" disabled="@IsRunning" @onclick="RenderWaveWithProsodyAsync">Render Wave (Prosody)</button>
    </div>

    <details class="example-cli-panel text-workflows">
        <summary>Text-to-Melody — CLI reference (@PlaygroundPresetCatalog.AllTextWorkflows.Count workflows)</summary>
        @foreach (var workflow in PlaygroundPresetCatalog.AllTextWorkflows)
        {
            <article class="text-workflow">
                <div class="example-cli-header">
                    <span class="badge badge-rail">@workflow.OutputRailShortLabel</span>
                    <span class="example-cli-action">Button: <strong>@workflow.PlaygroundButton</strong></span>
                </div>
                @if (!string.IsNullOrWhiteSpace(workflow.Notes))
                {
                    <p class="example-cli-notes">@workflow.Notes</p>
                }
                <ol class="cli-steps">
                    @foreach (var line in workflow.CliSteps)
                    {
                        <li>
                            <code class="cli-line">@line</code>
                            <button type="button" class="btn btn-secondary btn-copy-cli" @onclick="() => CopyCliLineAsync(line)">Copy</button>
                        </li>
                    }
                </ol>
            </article>
        }
        <p class="example-cli-file">
            Default compose text matches the input above (<code>@PlaygroundPresetCatalog.DefaultComposeText</code>).
            Replace quoted text in CLI commands when using your own lyrics.
            · <a href="@PlaygroundPresetCatalog.DocsExamplesUrl" target="_blank" rel="noopener noreferrer">examples catalog</a>
            · <a href="/doc.html?p=cli.md" target="_blank" rel="noopener noreferrer">CLI reference</a>
        </p>
    </details>

    @* CLI Examples split into two sections: MIDI-rail and Wave-rail. *@
    <div class="cli-examples-split">
        <details class="example-cli-panel cli-examples-section">
            <summary>A · MIDI examples — CLI (@MidiCliPresets.Count)</summary>
            @foreach (var preset in MidiCliPresets)
            {
                <article class="text-workflow">
                    <div class="example-cli-header">
                        <span class="badge badge-rail">@preset.OutputRailLabel</span>
                        <span class="example-cli-action">@preset.Title</span>
                    </div>
                    <ol class="cli-steps">
                        @foreach (var line in preset.CliSteps)
                        {
                            <li>
                                <code class="cli-line">@line</code>
                                <button type="button" class="btn btn-secondary btn-copy-cli" @onclick="() => CopyCliLineAsync(line)">Copy</button>
                            </li>
                        }
                    </ol>
                </article>
            }
        </details>

        <details class="example-cli-panel cli-examples-section">
            <summary>B · Wave examples — CLI (@WaveCliPresets.Count)</summary>
            @foreach (var preset in WaveCliPresets)
            {
                <article class="text-workflow">
                    <div class="example-cli-header">
                        <span class="badge badge-rail">@preset.OutputRailLabel</span>
                        <span class="example-cli-action">@preset.Title</span>
                    </div>
                    <ol class="cli-steps">
                        @foreach (var line in preset.CliSteps)
                        {
                            <li>
                                <code class="cli-line">@line</code>
                                <button type="button" class="btn btn-secondary btn-copy-cli" @onclick="() => CopyCliLineAsync(line)">Copy</button>
                            </li>
                        }
                    </ol>
                </article>
            }
        </details>
    </div>

    @* ===================================================================
       V10 Studio — redesigned bottom section. Split SSW + SoundCSS editors,
       SoundCSS info modal, CLI pattern selector, Play/Download. The top
       example showcase above is intentionally untouched.
       =================================================================== *@
    <section class="studio" aria-labelledby="studio-heading">
        <div class="studio-head">
            <h2 id="studio-heading">SoundScript Wave — Studio</h2>
            <p class="hint">
                Score on the left (<code>.ssw</code>), word-level
                <code>SoundCSS</code> on the right. Play renders in-browser through
                <code>SoundScript.Wave</code> (deterministic — identical input always
                produces byte-identical audio); the CLI preview below is the exact
                command for the selected render option.
            </p>
        </div>

        <div class="presets presets-wave">
            <span class="preset-label">Example:</span>
            <select class="example-select" @bind="SelectedWaveExampleKey" @bind:after="LoadStudioExampleAsync">
                <option value="wave-effects">Effects (delay + lowpass)</option>
                <option value="wave-speak">Speak (phoneme tones)</option>
                <option value="wave-humanize">Humanize</option>
                <option value="wave-effects-combined">Combined (wave-effects.ssw)</option>
                <option value="wave-full-song">Full song (full-song-wave.ss)</option>
                <option value="speech-only-wave">Speech-only (speech-only-wave.ss)</option>
                <option value="wave-vocal-stem">Vocal stem (wave-vocal-stem.ssw)</option>
                <option value="jingle-bells-vocal">Jingle Bells + offline vocal</option>
                <option value="jingle-bells-wordbank">Jingle Bells + WordBank vocal (V9)</option>
                <option value="showcase-jingle-bells-wave">Jingle Bells — Wave rail</option>
            </select>
            <button type="button" class="btn btn-secondary" @onclick="GenerateSafeExampleAsync">Generate example</button>
            @if (ActiveWavePreset is not null)
            {
                <span class="preset-active-title">@ActiveWavePreset.Title</span>
            }
        </div>

        <div class="studio-split">
            <div class="studio-pane" id="studio-left">
                <div class="studio-pane-header">
                    <span class="studio-pane-title">SSW Script</span>
                </div>
                <div class="studio-toolbar" role="toolbar" aria-label="SSW editor actions">
                    <button type="button" class="btn btn-secondary" @onclick="() => ResetEditorAsync(SswEditorId)">Reset</button>
                    <button type="button" class="btn btn-secondary" @onclick="() => ClearEditorAsync(SswEditorId)">Clear</button>
                    <button type="button" class="btn btn-secondary" @onclick="() => CopyEditorAsync(SswEditorId)">Copy</button>
                    <button type="button" class="btn btn-secondary" @onclick="() => UndoEditorAsync(SswEditorId)">Undo</button>
                    <button type="button" class="btn btn-secondary" @onclick="() => RedoEditorAsync(SswEditorId)">Redo</button>
                    <button type="button" class="btn btn-secondary" @onclick="() => ToggleThemeAsync(SswEditorId)">Theme</button>
                </div>
                <div class="editor-mount" id="@SswEditorId"></div>
            </div>

            <div class="studio-divider" id="studio-divider" role="separator" aria-orientation="vertical"></div>

            <div class="studio-pane studio-pane-right" id="studio-right">
                <div class="studio-pane-header">
                    <span class="studio-pane-title">SoundCSS</span>
                    <button type="button" class="icon-btn" title="SoundCSS syntax reference"
                            aria-label="SoundCSS syntax reference" @onclick="() => ShowSyntaxInfo = true">ⓘ</button>
                </div>
                <div class="studio-toolbar" role="toolbar" aria-label="SoundCSS editor actions">
                    <button type="button" class="btn btn-secondary" @onclick="() => ResetEditorAsync(CssEditorId)">Reset</button>
                    <button type="button" class="btn btn-secondary" @onclick="() => ClearEditorAsync(CssEditorId)">Clear</button>
                    <button type="button" class="btn btn-secondary" @onclick="() => CopyEditorAsync(CssEditorId)">Copy</button>
                    <button type="button" class="btn btn-secondary" @onclick="() => UndoEditorAsync(CssEditorId)">Undo</button>
                    <button type="button" class="btn btn-secondary" @onclick="() => RedoEditorAsync(CssEditorId)">Redo</button>
                    <button type="button" class="btn btn-secondary" @onclick="() => ToggleThemeAsync(CssEditorId)">Theme</button>
                </div>
                <div class="editor-mount" id="@CssEditorId"></div>
            </div>
        </div>

        <div class="studio-render">
            <div class="render-row">
                <label for="render-option">Render option:</label>
                <select id="render-option" class="render-select" @bind="SelectedPattern" @bind:after="UpdatePatternPreview">
                    @foreach (var pattern in RenderPatterns)
                    {
                        <option value="@pattern.Key">@pattern.Label</option>
                    }
                </select>
                <button type="button" class="btn btn-primary" disabled="@IsRunning" @onclick="PlayStudioAsync">
                    @if (IsRunning)
                    {
                        <span class="spinner"></span><text>Rendering…</text>
                    }
                    else
                    {
                        <text>▶ Play</text>
                    }
                </button>
                <button type="button" class="btn btn-secondary" @onclick="StopAsync">Stop</button>
                <button type="button" class="btn btn-secondary" disabled="@(StudioWavBytes is null)" @onclick="DownloadStudioAsync">Download WAV</button>
                <span class="badge badge-wave">SoundScript.Wave · no MIDI step</span>
            </div>
            <p class="render-desc">@CurrentPattern.Description</p>
            <div class="cli-preview">
                <code>@CliPreview</code>
                <button type="button" class="btn btn-secondary btn-copy-cli" @onclick="CopyCliPreviewAsync">Copy</button>
            </div>

            <div class="vocal-toggle-row">
                <label class="vocal-toggle" title="Loads the WordBank corpus on demand and renders speak lines with the full SoundScript.Vocal engine (SoundCSS applies to audio).">
                    <input type="checkbox" checked="@VocalEngineEnabled" @onchange="OnToggleVocalEngineAsync" disabled="@VocalCorpusLoading" />
                    <span>Enable In-Browser Vocal Engine</span>
                </label>
                @if (VocalCorpusLoading)
                {
                    <span class="vocal-toggle-status"><span class="spinner"></span>Loading corpus…</span>
                }
                else if (VocalEngineEnabled && VocalCorpusReady)
                {
                    <span class="vocal-toggle-status vocal-on">On · SoundCSS applies to speak lines (WordBank corpus loaded on demand).</span>
                }
                else
                {
                    <span class="vocal-toggle-status">Off · lightweight preview (no corpus download). SoundCSS shown in the CLI command.</span>
                }
            </div>
        </div>
    </section>

    @if (ShowSyntaxInfo)
    {
        <div class="modal-backdrop" @onclick="() => ShowSyntaxInfo = false">
            <div class="modal" @onclick:stopPropagation="true" role="dialog" aria-modal="true" aria-label="SoundCSS syntax">
                <div class="modal-header">
                    <h3>SoundCSS syntax</h3>
                    <button type="button" class="icon-btn" aria-label="Close" @onclick="() => ShowSyntaxInfo = false">✕</button>
                </div>
                <div class="modal-body">
                    <p class="hint">Word rules use a quoted selector; each attribute is optional.</p>
                    @foreach (var attr in SoundCssAttributes)
                    {
                        <div class="syntax-item">
                            <h4>@attr.Name</h4>
                            <span class="values">@attr.Values</span>
                        </div>
                    }
                    <div class="syntax-example">
                        <pre>@SyntaxExample</pre>
                        <button type="button" class="btn btn-secondary btn-copy-cli" @onclick="CopySyntaxExampleAsync">Copy example</button>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (ToastMessage is not null)
    {
        <div class="toast @(ToastIsError ? "" : "toast-success")" role="@(ToastIsError ? "alert" : "status")">
            @ToastMessage
        </div>
    }
</div>
